# Postgres connection string (Vercel Postgres / Neon / any Postgres host)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Long random string used to sign login session tokens — generate your own, don't reuse this
JWT_SECRET=replace-with-a-long-random-string

# Local dev API server port (used by server/dev-server.js and vite.config.js proxy)
PORT=3001
