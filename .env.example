# Postgres connection string (Vercel Postgres / Neon / any Postgres host)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Long random string used to sign login session tokens — generate your own, don't reuse this
JWT_SECRET=replace-with-a-long-random-string

# Local dev API server port (used by server/dev-server.js and vite.config.js proxy)
PORT=3001

# Gmail account used to send "forgot password" reset emails.
# GMAIL_USER is the sending Gmail address.
# GMAIL_APP_PASSWORD is a 16-character App Password (NOT your normal Gmail password) —
# generate one at https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=replace-with-a-gmail-app-password

# Base URL of the deployed/local frontend — used to build the password reset link sent by email.
APP_URL=http://localhost:5173
